<ui:FluentWindow x:Class="SoundPad.App.Dialogs.CategoryManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Manage Categories"
        Width="440" Height="520"
        MinWidth="440" MinHeight="520"
        MaxWidth="440" MaxHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Manage Categories"
                     ShowMinimize="False"
                     ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Tag20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,20">

                <TextBlock Text="CATEGORIES"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,8"/>

                <!-- Category list -->
                <ListBox x:Name="CategoryListBox"
                         Height="170"
                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                         BorderBrush="{DynamicResource CardBorderBrush}"
                         BorderThickness="1"
                         SelectionChanged="CategoryListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,7"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding CountText}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <ui:Button x:Name="CreateButton"
                               Content="Create"
                               Appearance="Secondary"
                               Click="Create_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Add20"/>
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button x:Name="RenameButton"
                               Content="Rename"
                               Appearance="Secondary"
                               IsEnabled="False"
                               Margin="8,0,0,0"
                               Click="Rename_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Edit20"/>
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button x:Name="DeleteButton"
                               Content="Delete"
                               Appearance="Secondary"
                               IsEnabled="False"
                               Margin="8,0,0,0"
                               Click="Delete_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Delete20"/>
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>

                <!-- Inline edit zone — shown for Create / Rename / Delete-with-move -->
                <Border x:Name="EditZone"
                        Visibility="Collapsed"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16,14"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock x:Name="EditZoneLabel"
                                   Text="New category name:"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6"/>

                        <ui:TextBox x:Name="EditBox"
                                    Visibility="Visible"
                                    Margin="0,0,0,10"
                                    KeyDown="EditBox_KeyDown"/>

                        <TextBlock x:Name="MoveToLabel"
                                   Text="Move sounds to:"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,6"/>

                        <ComboBox x:Name="MoveToCombo"
                                  Visibility="Collapsed"
                                  Margin="0,0,0,10"/>

                        <TextBlock x:Name="EditErrorText"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="Cancel"
                                       Appearance="Secondary"
                                       Width="80"
                                       Click="EditCancel_Click"/>
                            <ui:Button Content="Confirm"
                                       Appearance="Primary"
                                       Width="90"
                                       Margin="8,0,0,0"
                                       Click="EditConfirm_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Separator Margin="0,16,0,14"
                           Background="{DynamicResource CardBorderBrush}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Done"
                               Appearance="Primary"
                               Width="100"
                               Click="Done_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
