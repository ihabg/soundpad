<ui:FluentWindow x:Class="SoundPad.App.Dialogs.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Sound Color"
        Width="420" Height="660"
        MinWidth="420" MinHeight="660"
        MaxWidth="420" MaxHeight="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Sound Color"
                     ShowMinimize="False"
                     ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Color20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="24,16,24,20">

            <!-- ── PRESET COLORS ──────────────────────────────────────────────── -->
            <TextBlock Text="PRESET COLORS"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,10"/>

            <WrapPanel x:Name="PresetsPanel"
                       Margin="0,0,0,4"/>

            <Separator Margin="0,14,0,14"
                       Background="{DynamicResource CardBorderBrush}"/>

            <!-- ── CUSTOM COLOR ───────────────────────────────────────────────── -->
            <TextBlock Text="CUSTOM COLOR"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,10"/>

            <!-- HEX -->
            <TextBlock Text="HEX"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,5"/>
            <ui:TextBox x:Name="HexBox"
                        PlaceholderText="#RRGGBB"
                        MaxLength="7"
                        Margin="0,0,0,14"
                        TextChanged="HexBox_TextChanged"/>

            <!-- R -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="R"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Slider x:Name="RedSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="255"
                        VerticalAlignment="Center"
                        Margin="6,0,8,0"
                        ValueChanged="RgbSlider_ValueChanged"/>
                <ui:TextBox x:Name="RedBox"
                            Grid.Column="2"
                            MaxLength="3"
                            TextAlignment="Right"
                            TextChanged="RgbBox_TextChanged"/>
            </Grid>

            <!-- G -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="G"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Slider x:Name="GreenSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="255"
                        VerticalAlignment="Center"
                        Margin="6,0,8,0"
                        ValueChanged="RgbSlider_ValueChanged"/>
                <ui:TextBox x:Name="GreenBox"
                            Grid.Column="2"
                            MaxLength="3"
                            TextAlignment="Right"
                            TextChanged="RgbBox_TextChanged"/>
            </Grid>

            <!-- B -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="B"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Slider x:Name="BlueSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="255"
                        VerticalAlignment="Center"
                        Margin="6,0,8,0"
                        ValueChanged="RgbSlider_ValueChanged"/>
                <ui:TextBox x:Name="BlueBox"
                            Grid.Column="2"
                            MaxLength="3"
                            TextAlignment="Right"
                            TextChanged="RgbBox_TextChanged"/>
            </Grid>

            <Separator Margin="0,0,0,14"
                       Background="{DynamicResource CardBorderBrush}"/>

            <!-- ── PREVIEW ────────────────────────────────────────────────────── -->
            <TextBlock Text="PREVIEW"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,10"/>

            <Border x:Name="PreviewSwatch"
                    Height="52"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,0,10"/>

            <!-- Validation error -->
            <TextBlock x:Name="ErrorText"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,6"/>

            <!-- ── ACTIONS ────────────────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <ui:Button Content="Cancel"
                           Appearance="Secondary"
                           Width="100"
                           Margin="0,0,10,0"
                           Click="Cancel_Click"/>
                <ui:Button x:Name="ApplyButton"
                           Content="Apply"
                           Appearance="Primary"
                           Width="100"
                           Click="Apply_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
