<ui:FluentWindow x:Class="SoundPad.App.Dialogs.ConfirmRemoveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Remove Sound"
        Width="400" Height="256"
        MinWidth="400" MinHeight="256"
        MaxWidth="400" MaxHeight="256"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Remove Sound"
                     ShowMinimize="False"
                     ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Delete16"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="24,20,24,20">

            <!-- Sound name, trimmed with ellipsis if too long -->
            <TextBlock x:Name="SoundNameText"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,8"/>

            <!-- Action description -->
            <TextBlock Text="Remove this sound from your library?"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>

            <!-- Safety note -->
            <TextBlock Text="The audio file will not be deleted from disk."
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,26"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel"
                           Appearance="Secondary"
                           Width="100"
                           Margin="0,0,10,0"
                           IsCancel="True"
                           Click="Cancel_Click"/>
                <ui:Button Content="Remove"
                           Appearance="Danger"
                           Width="100"
                           Click="Remove_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
