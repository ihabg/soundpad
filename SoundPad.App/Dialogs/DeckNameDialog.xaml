<ui:FluentWindow x:Class="SoundPad.App.Dialogs.DeckNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Deck Name"
        Width="400" Height="230"
        MinWidth="400" MinHeight="230"
        MaxWidth="400" MaxHeight="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     x:Name="DialogTitleBar"
                     Title="Deck Name"
                     ShowMinimize="False"
                     ShowMaximize="False"/>

        <StackPanel Grid.Row="1" Margin="24,18,24,20">

            <TextBlock x:Name="InstructionText"
                       Text="Enter a name for this deck:"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,12"/>

            <ui:TextBox x:Name="NameBox"
                        PlaceholderText="e.g. Gaming, Work, Podcast…"
                        MaxLength="60"
                        Margin="0,0,0,8"
                        KeyDown="NameBox_KeyDown"/>

            <TextBlock x:Name="ErrorText"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       FontSize="12"
                       Visibility="Collapsed"
                       Margin="0,0,0,12"/>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="1"
                           Content="Cancel"
                           Appearance="Secondary"
                           Width="90"
                           Margin="0,0,10,0"
                           Click="Cancel_Click"/>
                <ui:Button x:Name="OkButton"
                           Grid.Column="2"
                           Content="OK"
                           Appearance="Primary"
                           Width="90"
                           Click="Ok_Click"/>
            </Grid>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
