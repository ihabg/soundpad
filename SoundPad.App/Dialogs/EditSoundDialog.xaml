<ui:FluentWindow x:Class="SoundPad.App.Dialogs.EditSoundDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Edit Sound"
        Width="400" Height="380"
        MinWidth="400" MinHeight="380"
        MaxWidth="400" MaxHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Edit Sound"
                     ShowMinimize="False"
                     ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Edit20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="24,18,24,20">

            <TextBlock Text="Name"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,6"/>
            <ui:TextBox x:Name="NameBox" Margin="0,0,0,18"/>

            <TextBlock Text="Category"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,6"/>
            <ComboBox x:Name="CategoryBox" IsEditable="True" Margin="0,0,0,18"/>

            <TextBlock Text="Hotkey"
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,6"/>
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,9"
                    Margin="0,0,0,26">
                <TextBlock x:Name="HotkeyDisplayText"
                           Text="No hotkey assigned"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="12"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Cancel"
                           Appearance="Secondary"
                           Width="100"
                           Margin="0,0,10,0"
                           Click="Cancel_Click"/>
                <ui:Button Content="Save"
                           Appearance="Primary"
                           Width="100"
                           Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
