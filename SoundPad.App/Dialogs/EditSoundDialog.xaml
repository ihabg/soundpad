<ui:FluentWindow x:Class="SoundPad.App.Dialogs.EditSoundDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Edit Sound"
        Width="490" Height="920"
        MinWidth="490" MinHeight="920"
        MaxWidth="490" MaxHeight="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Edit Sound"
                     ShowMinimize="False"
                     ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Edit20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,20">

                <!-- ── DETAILS ──────────────────────────────────────────────── -->
                <TextBlock Text="DETAILS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Name"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <ui:TextBox x:Name="NameBox" Margin="0,0,0,14"/>

                <TextBlock Text="Category"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="CategoryBox" IsEditable="True" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Tags"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ui:TextBox x:Name="TagsBox"
                                Grid.Column="1"
                                PlaceholderText="meme, game, voice"
                                ToolTip="Comma-separated tags"/>
                </Grid>

                <TextBlock Text="Volume"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,5"/>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock x:Name="VolumePctText"
                               DockPanel.Dock="Right"
                               Text="100%"
                               FontSize="12"
                               Width="40"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
                    <Slider x:Name="VolumeSlider"
                            Minimum="0"
                            Maximum="100"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"/>
                </DockPanel>

                <!-- ── EFFECTS ──────────────────────────────────────────────── -->
                <Separator Margin="0,10,0,14"
                           Background="{DynamicResource CardBorderBrush}"/>

                <TextBlock Text="EFFECTS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ReverseCheckBox"
                              Grid.Column="0"
                              Content="Reverse"
                              FontSize="12"
                              VerticalAlignment="Center"/>
                    <CheckBox x:Name="NormalizeCheckBox"
                              Grid.Column="1"
                              Content="Normalize"
                              FontSize="12"
                              VerticalAlignment="Center"/>
                    <ui:Button x:Name="ResetEffectsButton"
                               Grid.Column="2"
                               Content="Reset"
                               Appearance="Secondary"
                               FontSize="11"
                               Click="ResetEffects_Click"/>
                </Grid>

                <DockPanel Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Speed"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               Width="50"/>
                    <TextBlock x:Name="SpeedValueText"
                               DockPanel.Dock="Right"
                               Text="1.00×"
                               FontSize="12"
                               Width="44"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
                    <Slider x:Name="SpeedSlider"
                            Minimum="0.5"
                            Maximum="2.0"
                            Value="1.0"
                            TickFrequency="0.25"
                            IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="SpeedSlider_ValueChanged"/>
                </DockPanel>

                <TextBlock Text="Speed also changes pitch (vinyl-style)"
                           FontSize="10"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,2,0,8"/>

                <Separator Margin="0,10,0,14"
                           Background="{DynamicResource CardBorderBrush}"/>

                <!-- ── HOTKEY ────────────────────────────────────────────────── -->
                <TextBlock Text="HOTKEY"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,10"/>

                <DockPanel Margin="0,0,0,6" LastChildFill="True">
                    <ui:Button x:Name="ClearHotkeyButton"
                               DockPanel.Dock="Right"
                               Content="Clear"
                               Appearance="Secondary"
                               Margin="6,0,0,0"
                               Click="ClearHotkey_Click"/>
                    <ui:Button x:Name="ChangeHotkeyButton"
                               DockPanel.Dock="Right"
                               Content="Change"
                               Appearance="Secondary"
                               Click="ChangeHotkey_Click"/>
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,9"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="HotkeyDisplayText"
                                   Text="No hotkey assigned"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontSize="12"/>
                    </Border>
                </DockPanel>

                <Separator Margin="0,14,0,14"
                           Background="{DynamicResource CardBorderBrush}"/>

                <!-- ── TRIM &amp; FADE ─────────────────────────────────────── -->
                <TextBlock Text="TRIM &amp; FADE"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,4"/>

                <TextBlock x:Name="DurationText"
                           Text="Duration: —"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="Trim Start (s)"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <ui:TextBox x:Name="TrimStartBox"
                                    PlaceholderText="0.0 (play from start)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.Row="0">
                        <TextBlock Text="Trim End (s)"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <ui:TextBox x:Name="TrimEndBox"
                                    PlaceholderText="Empty = end of file"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="2">
                        <TextBlock Text="Fade In (s)"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <ui:TextBox x:Name="FadeInBox"
                                    PlaceholderText="0.0 (no fade)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.Row="2">
                        <TextBlock Text="Fade Out (s)"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,5"/>
                        <ui:TextBox x:Name="FadeOutBox"
                                    PlaceholderText="0.0 (no fade)"/>
                    </StackPanel>
                </Grid>

                <!-- Trim/fade validation error -->
                <TextBlock x:Name="TrimErrorText"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,4,0,4"/>

                <!-- ── TIMELINE TOOLS ────────────────────────────────────────── -->
                <DockPanel Margin="0,8,0,4" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <ToggleButton x:Name="SelectToolButton"
                                      Content="Select (A)"
                                      ToolTip="Select and drag blocks (A)"
                                      IsChecked="True"
                                      Padding="10,4"
                                      FontSize="11"
                                      Margin="0,0,4,0"
                                      Checked="SelectToolButton_Checked"/>
                        <ToggleButton x:Name="CutToolButton"
                                      Content="Cut (C)"
                                      ToolTip="Cut block at cursor position (C)"
                                      IsChecked="False"
                                      Padding="10,4"
                                      FontSize="11"
                                      Margin="0,0,4,0"
                                      Checked="CutToolButton_Checked"/>
                        <ui:Button x:Name="UndoButton"
                                   Content="Undo"
                                   ToolTip="Undo last edit (Ctrl+Z)"
                                   Appearance="Secondary"
                                   FontSize="11"
                                   IsEnabled="False"
                                   Margin="0,0,4,0"
                                   Click="UndoButton_Click">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ArrowUndo20"/>
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button x:Name="RedoButton"
                                   Content="Redo"
                                   ToolTip="Redo last undone edit (Ctrl+Y)"
                                   Appearance="Secondary"
                                   FontSize="11"
                                   IsEnabled="False"
                                   Click="RedoButton_Click">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ArrowRedo20"/>
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                    <ui:Button x:Name="DeleteCutButton"
                               DockPanel.Dock="Right"
                               Content="Remove Block"
                               ToolTip="Remove the selected block (Delete)"
                               Appearance="Secondary"
                               FontSize="11"
                               IsEnabled="False"
                               Click="DeleteCutButton_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Delete20"/>
                        </ui:Button.Icon>
                    </ui:Button>
                </DockPanel>

                <!-- Second toolbar row: Copy / Paste -->
                <DockPanel Margin="0,0,0,4" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <ui:Button x:Name="CopyButton"
                                   Content="Copy"
                                   ToolTip="Copy selected block (Ctrl+C)"
                                   Appearance="Secondary"
                                   FontSize="11"
                                   IsEnabled="False"
                                   Margin="0,0,4,0"
                                   Click="CopyButton_Click">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Copy20"/>
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button x:Name="PasteButton"
                                   Content="Paste"
                                   ToolTip="Paste copied block (Ctrl+V)"
                                   Appearance="Secondary"
                                   FontSize="11"
                                   IsEnabled="False"
                                   Click="PasteButton_Click">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ClipboardPaste20"/>
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </DockPanel>

                <!-- Snap cut to playhead -->
                <CheckBox x:Name="SnapToPlayheadCheckBox"
                          Content="Snap cut to playhead"
                          IsChecked="True"
                          FontSize="11"
                          HorizontalAlignment="Right"
                          Margin="0,2,0,4"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <!-- Zoom -->
                <DockPanel Margin="0,0,0,4" LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Zoom"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,6,0"/>
                    <TextBlock x:Name="ZoomText"
                               DockPanel.Dock="Right"
                               Text="1×"
                               FontSize="11"
                               Width="28"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <Slider x:Name="ZoomSlider"
                            Minimum="1"
                            Maximum="10"
                            Value="1"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                </DockPanel>

                <!-- ── WAVEFORM TIMELINE ─────────────────────────────────────── -->
                <Border Height="126"
                        Background="#1A1A1A"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        ClipToBounds="True"
                        Margin="0,0,0,0">
                    <ScrollViewer x:Name="WaveformScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden"
                                  SizeChanged="WaveformScrollViewer_SizeChanged">
                        <StackPanel Orientation="Vertical">
                            <Canvas x:Name="RulerCanvas"
                                    Height="20"
                                    Background="Transparent"
                                    IsHitTestVisible="False"/>
                            <Canvas x:Name="WaveformCanvas"
                                    Height="88"
                                    Background="Transparent"
                                    Cursor="Arrow"
                                    MouseLeftButtonDown="Waveform_MouseDown"
                                    MouseLeftButtonUp="Waveform_MouseUp"
                                    MouseMove="Waveform_MouseMove"
                                    MouseRightButtonDown="Waveform_MouseRightDown"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Block info -->
                <TextBlock x:Name="BlockInfoText"
                           FontSize="10"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,3,0,0"
                           Text=""/>

                <!-- timeline legend -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="LimeGreen" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text=" Trim Start   " FontSize="10"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <Ellipse Grid.Column="2" Width="8" Height="8" Fill="OrangeRed" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text=" Trim End   " FontSize="10"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="4" Width="12" Height="8" VerticalAlignment="Center">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5A32C832" Offset="0"/>
                                <GradientStop Color="#0032C832" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock Grid.Column="5" Text=" Fade   " FontSize="10"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="6" Width="12" Height="8" Fill="#99555555" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="7" Text=" Removed   " FontSize="10"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <Line Grid.Column="8" X1="0" Y1="4" X2="12" Y2="4"
                          Stroke="White" StrokeThickness="1.5"
                          StrokeDashArray="3,2" VerticalAlignment="Center"/>
                </Grid>

                <Separator Margin="0,12,0,14"
                           Background="{DynamicResource CardBorderBrush}"/>

                <!-- ── PREVIEW ───────────────────────────────────────────────── -->
                <TextBlock Text="PREVIEW"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,10"/>

                <DockPanel LastChildFill="False">
                    <ui:Button x:Name="PreviewButton"
                               DockPanel.Dock="Left"
                               Appearance="Secondary"
                               Content="Play Preview"
                               Click="Preview_Click">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Play20"/>
                        </ui:Button.Icon>
                    </ui:Button>
                    <TextBlock x:Name="PreviewStatusText"
                               DockPanel.Dock="Left"
                               Text=""
                               FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </DockPanel>

                <Separator Margin="0,16,0,14"
                           Background="{DynamicResource CardBorderBrush}"/>

                <!-- ── ACTIONS ───────────────────────────────────────────────── -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel"
                               Appearance="Secondary"
                               Width="100"
                               Margin="0,0,10,0"
                               Click="Cancel_Click"/>
                    <ui:Button Content="Save"
                               Appearance="Primary"
                               Width="100"
                               Click="Save_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
