<ui:FluentWindow x:Class="SoundPad.App.Dialogs.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Set Hotkey"
        Width="420" Height="300"
        MinWidth="420" MinHeight="300"
        MaxWidth="420" MaxHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     x:Name="DialogTitleBar"
                     Title="Set Hotkey"
                     ShowMinimize="False"
                     ShowMaximize="False"/>

        <StackPanel Grid.Row="1" Margin="24,18,24,20">

            <TextBlock x:Name="InstructionText"
                       Text="Press a key combination for this sound."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Height="64"
                    Margin="0,0,0,10">
                <TextBlock x:Name="CapturedText"
                           Text="..."
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Border>

            <TextBlock Text="Esc to cancel  ·  Backspace to clear"
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,22"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0"
                           Content="Clear Hotkey"
                           Appearance="Secondary"
                           HorizontalAlignment="Left"
                           Click="Clear_Click"/>
                <ui:Button Grid.Column="1"
                           Content="Cancel"
                           Appearance="Secondary"
                           Width="90"
                           Margin="0,0,10,0"
                           Click="Cancel_Click"/>
                <ui:Button x:Name="SaveButton"
                           Grid.Column="2"
                           Content="Save"
                           Appearance="Primary"
                           Width="90"
                           IsEnabled="False"
                           Click="Save_Click"/>
            </Grid>

        </StackPanel>
    </Grid>
</ui:FluentWindow>
