<Window x:Class="SoundPad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SoundPad" Height="400" Width="420"
        Background="#1E1E1E"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">

        <TextBlock Text="SoundPad"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20" />

        <!-- 2x2 grid of sound buttons. UniformGrid divides its space equally across all cells. -->
        <UniformGrid Rows="2" Columns="2" Margin="0,0,0,12">
            <Button Content="Sound 1" Height="60"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555555"
                    FontSize="14" Cursor="Hand" Margin="4"
                    Click="Sound1_Click" />
            <Button Content="Sound 2" Height="60"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555555"
                    FontSize="14" Cursor="Hand" Margin="4"
                    Click="Sound2_Click" />
            <Button Content="Sound 3" Height="60"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555555"
                    FontSize="14" Cursor="Hand" Margin="4"
                    Click="Sound3_Click" />
            <Button Content="Sound 4" Height="60"
                    Background="#3C3C3C" Foreground="White" BorderBrush="#555555"
                    FontSize="14" Cursor="Hand" Margin="4"
                    Click="Sound4_Click" />
        </UniformGrid>

        <Button x:Name="StopButton"
                Content="Stop"
                Height="40"
                Background="#5A2020" Foreground="White" BorderBrush="#7A3030"
                FontSize="14" Cursor="Hand"
                Margin="4,0,4,16"
                Click="StopButton_Click" />

        <TextBlock x:Name="StatusText"
                   Text="Ready"
                   Foreground="#AAAAAA"
                   FontSize="13"
                   HorizontalAlignment="Center" />

    </StackPanel>
</Window>
