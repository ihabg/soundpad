<ui:FluentWindow x:Class="SoundPad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="SoundPad" Height="760" Width="1100"
        MinWidth="900" MinHeight="560"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Loaded="MainWindow_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar: WPF UI handles drag, minimize/maximize/close, and snap natively ── -->
        <ui:TitleBar Grid.Row="0" Title="SoundPad">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="MusicNote2Play20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- ── Scrollable main content ──────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,16,28,24">

                <!-- ── Top row: Audio Routing | Microphone ─────────────────────── -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0" Padding="20">
                        <StackPanel>
                            <TextBlock Text="AUDIO ROUTING"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Monitor Output"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="MonitorComboBox"
                                      SelectionChanged="MonitorComboBox_SelectionChanged"/>

                            <TextBlock Text="Virtual / Cable Output"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,14,0,6"/>
                            <ComboBox x:Name="VirtualComboBox"
                                      SelectionChanged="VirtualComboBox_SelectionChanged"/>
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="2" Padding="20">
                        <StackPanel>
                            <TextBlock Text="MICROPHONE"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="Input Device"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="MicComboBox"
                                      Margin="0,0,0,16"
                                      SelectionChanged="MicComboBox_SelectionChanged"/>

                            <ui:ToggleSwitch x:Name="MicPassthroughCheckBox"
                                             Content="Pass microphone to virtual output"
                                             Margin="0,0,0,16"
                                             Checked="MicPassthroughCheckBox_Checked"
                                             Unchecked="MicPassthroughCheckBox_Unchecked"/>

                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Volume"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           Width="52"/>
                                <TextBlock x:Name="MicVolumeLabel"
                                           DockPanel.Dock="Right"
                                           Text="80%"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Width="38"/>
                                <Slider x:Name="MicVolumeSlider"
                                        Minimum="0" Maximum="100" Value="80"
                                        VerticalAlignment="Center"
                                        ValueChanged="MicVolumeSlider_ValueChanged"/>
                            </DockPanel>
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- ── Sound Library card ──────────────────────────────────────── -->
                <ui:Card Padding="20">
                    <StackPanel>

                        <!-- Library header: label + count badge + Add button -->
                        <DockPanel Margin="0,0,0,16">
                            <ui:Button DockPanel.Dock="Right"
                                       Content="Add Sound"
                                       Appearance="Primary"
                                       Click="AddSound_Click">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="AddCircle20"/>
                                </ui:Button.Icon>
                            </ui:Button>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SOUND LIBRARY"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ui:Badge x:Name="LibraryCountText"
                                          Content="0"
                                          Appearance="Secondary"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Search + Category filter toolbar -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>

                            <ui:TextBox x:Name="SearchBox"
                                        Grid.Column="0"
                                        PlaceholderText="Search sounds..."
                                        TextChanged="SearchBox_TextChanged">
                                <ui:TextBox.Icon>
                                    <ui:SymbolIcon Symbol="Search20"/>
                                </ui:TextBox.Icon>
                            </ui:TextBox>

                            <ComboBox x:Name="CategoryFilter"
                                      Grid.Column="2"
                                      SelectionChanged="CategoryFilter_SelectionChanged"/>
                        </Grid>

                        <!-- Sound pad grid (populated in code-behind) -->
                        <WrapPanel x:Name="SoundsPanel"/>

                        <!-- Empty library message -->
                        <TextBlock x:Name="EmptyLibraryText"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,4"
                                   Visibility="Collapsed"/>

                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer: status + Stop All ───────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="28,12,28,16">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="11"
                           Text="Ready"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,8"/>
                <ui:Button Content="Stop All Sounds"
                           Appearance="Danger"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Center"
                           Height="42"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Click="StopButton_Click">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Stop24"/>
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Border>

    </Grid>
</ui:FluentWindow>
