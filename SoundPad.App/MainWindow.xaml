<ui:FluentWindow x:Class="SoundPad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="SoundPad" Height="760" Width="1100"
        MinWidth="900" MinHeight="560"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Loaded="MainWindow_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar: WPF UI handles drag, minimize/maximize/close, and snap natively ── -->
        <ui:TitleBar Grid.Row="0" Title="SoundPad">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="MusicNote2Play20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- ── Tabs: Sound Library | Settings ──────────────────────────────────── -->
        <TabControl Grid.Row="1" Margin="0">

            <TabItem Header="Sound Library">
                <Grid Margin="24,18,24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar: label + count + Add Sound, then Search + Category -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,14">
                        <DockPanel Margin="0,0,0,14">
                            <ui:Button DockPanel.Dock="Right"
                                       Content="Add Sound"
                                       Appearance="Primary"
                                       Click="AddSound_Click">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="AddCircle20"/>
                                </ui:Button.Icon>
                            </ui:Button>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SOUND LIBRARY"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ui:Badge x:Name="LibraryCountText"
                                          Content="0"
                                          Appearance="Secondary"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="190"/>
                            </Grid.ColumnDefinitions>

                            <ui:TextBox x:Name="SearchBox"
                                        Grid.Column="0"
                                        PlaceholderText="Search sounds..."
                                        TextChanged="SearchBox_TextChanged">
                                <ui:TextBox.Icon>
                                    <ui:SymbolIcon Symbol="Search20"/>
                                </ui:TextBox.Icon>
                            </ui:TextBox>

                            <ComboBox x:Name="CategoryFilter"
                                      Grid.Column="2"
                                      SelectionChanged="CategoryFilter_SelectionChanged"/>
                        </Grid>
                    </StackPanel>

                    <!-- Column header (pinned above the scrollable rows) -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6,6,0,0"
                            Padding="14,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="84"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="NAME" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="CATEGORY" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="HOTKEY" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="VOLUME" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="5" Text="CREATED" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable rows -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,6,6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <StackPanel x:Name="SoundsPanel"/>
                                <TextBlock x:Name="EmptyLibraryText"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="14,18,14,18"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,18,24,16">

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Card Grid.Column="0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="AUDIO ROUTING"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="Monitor Output"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="MonitorComboBox"
                                              SelectionChanged="MonitorComboBox_SelectionChanged"/>

                                    <TextBlock Text="Virtual / Cable Output"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,14,0,6"/>
                                    <ComboBox x:Name="VirtualComboBox"
                                              SelectionChanged="VirtualComboBox_SelectionChanged"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Grid.Column="2" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="MICROPHONE"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="Input Device"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="MicComboBox"
                                              Margin="0,0,0,16"
                                              SelectionChanged="MicComboBox_SelectionChanged"/>

                                    <ui:ToggleSwitch x:Name="MicPassthroughCheckBox"
                                                     Content="Pass microphone to virtual output"
                                                     Margin="0,0,0,16"
                                                     Checked="MicPassthroughCheckBox_Checked"
                                                     Unchecked="MicPassthroughCheckBox_Unchecked"/>

                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="Volume"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   Width="52"/>
                                        <TextBlock x:Name="MicVolumeLabel"
                                                   DockPanel.Dock="Right"
                                                   Text="80%"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Width="38"/>
                                        <Slider x:Name="MicVolumeSlider"
                                                Minimum="0" Maximum="100" Value="80"
                                                VerticalAlignment="Center"
                                                ValueChanged="MicVolumeSlider_ValueChanged"/>
                                    </DockPanel>
                                </StackPanel>
                            </ui:Card>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Footer: status + fixed-size Stop All ────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="Stop All Sounds"
                           Appearance="Danger"
                           Width="200"
                           Height="44"
                           FontWeight="SemiBold"
                           Click="StopButton_Click">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Stop24"/>
                    </ui:Button.Icon>
                </ui:Button>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,16,0"
                           Text="Ready"/>
            </DockPanel>
        </Border>

    </Grid>
</ui:FluentWindow>
