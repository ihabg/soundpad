<Window x:Class="SoundPad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SoundPad" Height="760" Width="1100"
        MinWidth="900" MinHeight="560"
        Background="#0C0C0C"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="MainWindow_Loaded"
        Closing="Window_Closing">

    <!-- WindowChrome: extends client area over the caption; keeps native resize + snap -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ═══ Thin dark ScrollBar ═══════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
            <Setter Property="MinWidth"   Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#111111" CornerRadius="3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Fill="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBg"
                                                        Background="#2E2E2E"
                                                        CornerRadius="3"
                                                        Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Background" Value="#4A4A4A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Background" Value="#3B82F6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Fill="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Width"     Value="Auto"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ Title bar: standard window control button ═══════════════════ -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Arrow"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#252525"/>
                                <Setter Property="Foreground"                     Value="#DDDDDD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#303030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Title bar: close button with red hover ══════════════════════ -->
        <Style x:Key="TitleBarCloseButton" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Arrow"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground"                     Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground"                     Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark ComboBox ════════════════════════════════════════════════ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="#181818"/>
            <Setter Property="Foreground"               Value="#C0C0C0"/>
            <Setter Property="BorderBrush"              Value="#272727"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels"      Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <ToggleButton Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Grid IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="26"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 5 L 8 0"
                                      Stroke="#424242"
                                      StrokeThickness="1.5"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="0,1,4,0"/>
                            </Grid>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   AllowsTransparency="False">
                                <Border Background="#1A1A1A"
                                        BorderBrush="#2E2E2E"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Margin="0,4,0,4">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#383838"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Padding"    Value="11,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0D1F3C"/>
                                <Setter Property="Foreground" Value="#60A5FA"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"  Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#142A4C"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark TextBox ══════════════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="#161616"/>
            <Setter Property="Foreground"               Value="#C0C0C0"/>
            <Setter Property="BorderBrush"              Value="#272727"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="11,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"               Value="#C0C0C0"/>
            <Setter Property="SelectionBrush"           Value="#0D1F3C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#383838"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Dark CheckBox with green check ══════════════════════════════ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"        Value="#787878"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder"
                                    Width="17" Height="17"
                                    Background="#181818"
                                    BorderBrush="#343434"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,0,9,0"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 2 8 L 6 12 L 14 3"
                                      Stroke="#22C55E"
                                      StrokeThickness="1.8"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background"  Value="#0A1C10"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#1A7A3A"/>
                                <Setter TargetName="CheckMark"   Property="Visibility"  Value="Visible"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#555555"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Slim Slider with blue fill ═══════════════════════════════════ -->
        <Style TargetType="Slider">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Focusable"           Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Focusable="False" Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#3B82F6" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Focusable="False" Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#212121" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ThumbEllipse"
                                                         Fill="#CCCCCC"
                                                         Width="11" Height="11"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#FFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#60A5FA"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Sound card — large play area button ══════════════════════════ -->
        <Style x:Key="CardPlayButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Foreground"                 Value="#E8E8E8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="16,18,16,14"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PlayBg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PlayBg" Property="Background" Value="#171D2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PlayBg" Property="Background" Value="#1A2035"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Sound card — subtle Edit / Remove buttons ════════════════════ -->
        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBg" Property="Background" Value="#1D1D1D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionBg" Property="Background" Value="#242424"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Primary button (+ Add Sound) ═════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#0A1C10"/>
            <Setter Property="Foreground"      Value="#22C55E"/>
            <Setter Property="BorderBrush"     Value="#143820"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0F2A18"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#060E08"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Danger button (Stop All) — full-width capable ════════════════ -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background"      Value="#1C0808"/>
            <Setter Property="Foreground"      Value="#EF4444"/>
            <Setter Property="BorderBrush"     Value="#2C1010"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#280C0C"/>
                                <Setter Property="Foreground" Value="#F87171"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A1010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root border: named so OnStateChanged can adjust padding for maximized window -->
    <Border x:Name="RootContainer" Background="#0C0C0C">
        <DockPanel>

            <!-- ── Custom title bar ─────────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Height="40"
                    Background="#131313"
                    BorderBrush="#1A1A1A"
                    BorderThickness="0,0,0,1">
                <DockPanel>

                    <!-- Window control buttons (right); must be hit-testable in chrome -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button Content="─" Style="{StaticResource TitleBarButton}" Click="TitleBar_Minimize"
                                FontSize="10" Foreground="#555555"/>
                        <!-- MaxRestore: icon switches based on WindowState via DataTrigger -->
                        <Button Click="TitleBar_MaxRestore">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
                                    <Setter Property="Content" Value="□"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WindowState,
                                                     RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="Maximized">
                                            <Setter Property="Content" Value="❐"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="✕" Style="{StaticResource TitleBarCloseButton}" Click="TitleBar_Close"/>
                    </StackPanel>

                    <!-- App identity (left; rest of bar is draggable by default) -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0">
                        <Ellipse Width="7" Height="7"
                                 Fill="#22C55E"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="SoundPad"
                                   Foreground="#E0E0E0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="soundboard"
                                   Foreground="#222222"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,1,0,0"/>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- ── Footer: status + Stop All ───────────────────────────────────── -->
            <Border DockPanel.Dock="Bottom"
                    Background="#111111"
                    BorderBrush="#1A1A1A"
                    BorderThickness="0,1,0,0"
                    Padding="28,12,28,14">
                <StackPanel>
                    <!-- Subtle status line above the big button -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse x:Name="StatusDot"
                                 Width="5" Height="5"
                                 Fill="#252525"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText"
                                   Foreground="#333333"
                                   FontSize="11"
                                   Text="Ready"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <!-- Full-width Stop All command -->
                    <Button Content="⏹  Stop All Sounds"
                            Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Stretch"
                            Click="StopButton_Click"/>
                </StackPanel>
            </Border>

            <!-- ── Scrollable main content ──────────────────────────────────────── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,18,28,24">

                    <!-- ── Top row: Audio Routing | Microphone ─────────────────── -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Audio Routing card -->
                        <Border Grid.Column="0"
                                Background="#111111"
                                BorderBrush="#1E1E1E"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="20">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Rectangle DockPanel.Dock="Left"
                                               Width="3" Height="13"
                                               Fill="#3B82F6"
                                               RadiusX="1.5" RadiusY="1.5"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="AUDIO ROUTING"
                                               Foreground="#363636"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </DockPanel>

                                <TextBlock Text="Monitor Output"
                                           Foreground="#424242"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="MonitorComboBox"
                                          SelectionChanged="MonitorComboBox_SelectionChanged"/>

                                <TextBlock Text="Virtual / Cable Output"
                                           Foreground="#424242"
                                           FontSize="11"
                                           Margin="0,14,0,6"/>
                                <ComboBox x:Name="VirtualComboBox"
                                          SelectionChanged="VirtualComboBox_SelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Microphone card -->
                        <Border Grid.Column="2"
                                Background="#111111"
                                BorderBrush="#1E1E1E"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="20">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Rectangle DockPanel.Dock="Left"
                                               Width="3" Height="13"
                                               Fill="#22C55E"
                                               RadiusX="1.5" RadiusY="1.5"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Text="MICROPHONE"
                                               Foreground="#363636"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </DockPanel>

                                <TextBlock Text="Input Device"
                                           Foreground="#424242"
                                           FontSize="11"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="MicComboBox"
                                          Margin="0,0,0,14"
                                          SelectionChanged="MicComboBox_SelectionChanged"/>

                                <CheckBox x:Name="MicPassthroughCheckBox"
                                          Content="Pass microphone to virtual output"
                                          Margin="0,0,0,14"
                                          Checked="MicPassthroughCheckBox_Checked"
                                          Unchecked="MicPassthroughCheckBox_Unchecked"/>

                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Volume"
                                               Foreground="#424242"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               Width="52"/>
                                    <TextBlock x:Name="MicVolumeLabel"
                                               DockPanel.Dock="Right"
                                               Text="80%"
                                               Foreground="#363636"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Width="38"/>
                                    <Slider x:Name="MicVolumeSlider"
                                            Minimum="0" Maximum="100" Value="80"
                                            VerticalAlignment="Center"
                                            ValueChanged="MicVolumeSlider_ValueChanged"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Sound Library card ─────────────────────────────────── -->
                    <Border Background="#111111"
                            BorderBrush="#1E1E1E"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="20">
                        <StackPanel>

                            <!-- Library header: amber accent + count badge + Add button -->
                            <DockPanel Margin="0,0,0,16">
                                <Rectangle DockPanel.Dock="Left"
                                           Width="3" Height="13"
                                           Fill="#F59E0B"
                                           RadiusX="1.5" RadiusY="1.5"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <Button DockPanel.Dock="Right"
                                        Content="+ Add Sound"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="AddSound_Click"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="SOUND LIBRARY"
                                               Foreground="#363636"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Border Background="#181818"
                                            BorderBrush="#212121"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="7,2"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="LibraryCountText"
                                                   Text="0"
                                                   Foreground="#444444"
                                                   FontSize="10"/>
                                    </Border>
                                </StackPanel>
                            </DockPanel>

                            <!-- Search + Category filter toolbar -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <TextBox x:Name="SearchBox"
                                             TextChanged="SearchBox_TextChanged"/>
                                    <TextBlock Text="Search sounds..."
                                               Foreground="#252525"
                                               FontSize="12"
                                               IsHitTestVisible="False"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <ComboBox x:Name="CategoryFilter"
                                          Grid.Column="2"
                                          SelectionChanged="CategoryFilter_SelectionChanged"/>
                            </Grid>

                            <!-- Sound pad grid (populated in code-behind) -->
                            <WrapPanel x:Name="SoundsPanel"/>

                            <!-- Empty library message -->
                            <TextBlock x:Name="EmptyLibraryText"
                                       Foreground="#262626"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,4"
                                       Visibility="Collapsed"/>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</Window>
