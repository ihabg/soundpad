<Window x:Class="SoundPad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SoundPad" Height="720" Width="440"
        MinHeight="480"
        Background="#1A1A1A"
        ResizeMode="CanResize"
        Loaded="MainWindow_Loaded"
        Closing="Window_Closing">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,20">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <TextBlock Text="SoundPad"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- ── Audio Routing Card ──────────────────────────────────── -->
            <Border Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,10"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="AUDIO ROUTING"
                               Foreground="#888888"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <TextBlock Text="Monitor Output"
                               Foreground="#BBBBBB"
                               FontSize="12"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="MonitorComboBox"
                              Height="30"
                              Margin="0,0,0,10"
                              SelectionChanged="MonitorComboBox_SelectionChanged" />

                    <TextBlock Text="Virtual Output"
                               Foreground="#BBBBBB"
                               FontSize="12"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="VirtualComboBox"
                              Height="30"
                              SelectionChanged="VirtualComboBox_SelectionChanged" />
                </StackPanel>
            </Border>

            <!-- ── Microphone Card ────────────────────────────────────── -->
            <Border Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,10"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="MICROPHONE"
                               Foreground="#888888"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <TextBlock Text="Microphone Input"
                               Foreground="#BBBBBB"
                               FontSize="12"
                               Margin="0,0,0,4" />
                    <ComboBox x:Name="MicComboBox"
                              Height="30"
                              Margin="0,0,0,10"
                              SelectionChanged="MicComboBox_SelectionChanged" />

                    <CheckBox x:Name="MicPassthroughCheckBox"
                              Content="Send microphone to virtual output"
                              Foreground="White"
                              Margin="0,0,0,10"
                              Checked="MicPassthroughCheckBox_Checked"
                              Unchecked="MicPassthroughCheckBox_Unchecked" />

                    <DockPanel>
                        <TextBlock Text="Mic Volume"
                                   Foreground="#BBBBBB"
                                   FontSize="12"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <Slider x:Name="MicVolumeSlider"
                                Minimum="0" Maximum="100" Value="80"
                                VerticalAlignment="Center"
                                ValueChanged="MicVolumeSlider_ValueChanged" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Sound Library Card ─────────────────────────────────── -->
            <Border Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,10"
                    Padding="16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="SOUND LIBRARY"
                                   Foreground="#888888"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left" />
                        <Button Content="+ Add Sound"
                                DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Height="26"
                                Padding="12,0"
                                Background="#2A5C2A"
                                Foreground="White"
                                BorderBrush="#3A7A3A"
                                FontSize="12"
                                Cursor="Hand"
                                Click="AddSound_Click" />
                    </DockPanel>

                    <!-- Dynamic sound buttons go here -->
                    <WrapPanel x:Name="SoundsPanel" />

                    <TextBlock x:Name="EmptyLibraryText"
                               Text="No sounds yet. Click &quot;+ Add Sound&quot; to import an audio file."
                               Foreground="#555555"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- ── Stop All ───────────────────────────────────────────── -->
            <Button Content="Stop All"
                    Height="40"
                    Background="#5A2020"
                    Foreground="White"
                    BorderBrush="#7A3030"
                    FontSize="14"
                    Cursor="Hand"
                    Margin="0,0,0,10"
                    Click="StopButton_Click" />

            <!-- ── Status ─────────────────────────────────────────────── -->
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Foreground="#666666"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />

        </StackPanel>
    </ScrollViewer>
</Window>
