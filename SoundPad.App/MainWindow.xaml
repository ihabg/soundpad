<ui:FluentWindow x:Class="SoundPad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="SoundPad" Height="760" Width="1100"
        MinWidth="900" MinHeight="560"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        Loaded="MainWindow_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar: WPF UI handles drag, minimize/maximize/close, and snap natively ── -->
        <ui:TitleBar Grid.Row="0" Title="SoundPad">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="MusicNote2Play20"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- ── Tabs: Sound Library | Settings ──────────────────────────────────── -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="0"
                    SelectionChanged="MainTabControl_SelectionChanged">

            <TabItem Header="Sound Library">
                <Grid Margin="24,18,24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Deck chips bar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="True">
                        <ui:Button DockPanel.Dock="Right"
                                   x:Name="AddDeckButton"
                                   Appearance="Secondary"
                                   Padding="6"
                                   Margin="6,0,0,0"
                                   Click="AddDeck_Click"
                                   ToolTip="Add new deck">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Add20"/>
                            </ui:Button.Icon>
                        </ui:Button>
                        <ScrollViewer x:Name="DeckScroller"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="DeckChipsPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- Toolbar: label + count + Add Sound, then Search + Category -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,14">
                        <DockPanel Margin="0,0,0,14">
                            <ui:Button DockPanel.Dock="Right"
                                       Content="Add Sound"
                                       Appearance="Primary"
                                       Click="AddSound_Click">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="AddCircle20"/>
                                </ui:Button.Icon>
                            </ui:Button>
                            <ui:Button DockPanel.Dock="Right"
                                       Content="Categories"
                                       Appearance="Secondary"
                                       Margin="0,0,8,0"
                                       Click="CategoryManager_Click">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Tag20"/>
                                </ui:Button.Icon>
                            </ui:Button>
                            <ComboBox x:Name="GridSizeCombo"
                                      DockPanel.Dock="Right"
                                      Width="96"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"
                                      ToolTip="Pad size"
                                      Visibility="Collapsed"
                                      SelectionChanged="GridSizeCombo_SelectionChanged">
                                <ComboBoxItem Content="Small"/>
                                <ComboBoxItem Content="Medium"/>
                                <ComboBoxItem Content="Large"/>
                            </ComboBox>
                            <ui:Button x:Name="GridCompactButton"
                                       DockPanel.Dock="Right"
                                       Content="Compact"
                                       Appearance="Secondary"
                                       Padding="8,4"
                                       FontSize="11"
                                       Margin="0,0,4,0"
                                       ToolTip="Toggle compact pad mode"
                                       Visibility="Collapsed"
                                       Click="GridCompactButton_Click"/>
                            <ui:Button x:Name="MiniModeButton"
                                       DockPanel.Dock="Right"
                                       Content="Mini"
                                       Appearance="Secondary"
                                       Padding="8,4"
                                       FontSize="11"
                                       Margin="0,0,4,0"
                                       ToolTip="Open Mini Mode floating soundboard"
                                       Click="MiniModeButton_Click"/>
                            <ui:Button x:Name="GridViewButton"
                                       DockPanel.Dock="Right"
                                       Appearance="Secondary"
                                       Padding="6,4"
                                       Margin="0,0,4,0"
                                       ToolTip="Grid View"
                                       Click="GridViewButton_Click">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="Grid20"/>
                                </ui:Button.Icon>
                            </ui:Button>
                            <ui:Button x:Name="ListViewButton"
                                       DockPanel.Dock="Right"
                                       Appearance="Primary"
                                       Padding="6,4"
                                       Margin="0,0,4,0"
                                       ToolTip="List View"
                                       Click="ListViewButton_Click">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="AppsList20"/>
                                </ui:Button.Icon>
                            </ui:Button>
                            <!-- Instant Replay recording indicator — visible only when IR is ON -->
                            <Border x:Name="InstantReplayRecPill"
                                    DockPanel.Dock="Right"
                                    Visibility="Collapsed"
                                    Background="#D32F2F"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0">
                                <TextBlock Text="● REC"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SOUND LIBRARY"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ui:Badge x:Name="LibraryCountText"
                                          Content="0"
                                          Appearance="Secondary"
                                          Margin="10,0,0,0"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>

                        <StackPanel>
                            <!-- Row 1: Search -->
                            <ui:TextBox x:Name="SearchBox"
                                        PlaceholderText="Search sounds..."
                                        ClearButtonEnabled="True"
                                        Margin="0,0,0,6"
                                        TextChanged="SearchBox_TextChanged">
                                <ui:TextBox.Icon>
                                    <ui:SymbolIcon Symbol="Search20"/>
                                </ui:TextBox.Icon>
                            </ui:TextBox>

                            <!-- Row 2: Category | Tag | Sort -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition x:Name="TagFilterColumn" Width="0"/>
                                    <ColumnDefinition x:Name="TagFilterSpacerColumn" Width="0"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="CategoryFilter"
                                          Grid.Column="0"
                                          SelectionChanged="CategoryFilter_SelectionChanged"/>

                                <ComboBox x:Name="TagFilter"
                                          Grid.Column="2"
                                          Visibility="Collapsed"
                                          SelectionChanged="TagFilter_SelectionChanged"/>

                                <ComboBox x:Name="SortBox"
                                          Grid.Column="4"
                                          SelectionChanged="SortBox_SelectionChanged">
                                    <ComboBoxItem Content="Manual order"    Tag="Manual"/>
                                    <ComboBoxItem Content="Name A–Z"        Tag="Name A-Z"/>
                                    <ComboBoxItem Content="Name Z–A"        Tag="Name Z-A"/>
                                    <ComboBoxItem Content="Newest first"    Tag="Newest"/>
                                    <ComboBoxItem Content="Oldest first"    Tag="Oldest"/>
                                    <ComboBoxItem Content="Category"        Tag="Category"/>
                                    <ComboBoxItem Content="Favorites first" Tag="Favorites"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Column header (pinned above the scrollable rows) -->
                    <Border x:Name="ColumnHeaderBorder"
                            Grid.Row="2"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6,6,0,0"
                            Padding="14,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="95"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="NAME" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="CATEGORY" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="HOTKEY" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="4" Text="VOLUME" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="5" Text="CREATED" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable rows -->
                    <Border x:Name="SoundsAreaBorder"
                            Grid.Row="3"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,6,6"
                            AllowDrop="True"
                            DragEnter="SoundsArea_DragEnter"
                            DragOver="SoundsArea_DragOver"
                            DragLeave="SoundsArea_DragLeave"
                            Drop="SoundsArea_Drop">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <StackPanel x:Name="SoundsPanel"/>
                                <WrapPanel x:Name="GridPanel"
                                           Orientation="Horizontal"
                                           Margin="8,8,4,8"/>
                                <TextBlock x:Name="EmptyLibraryText"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="14,18,14,18"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,18,24,16">

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Card Grid.Column="0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="AUDIO ROUTING"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="Monitor Output"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="MonitorComboBox"
                                              SelectionChanged="MonitorComboBox_SelectionChanged"/>

                                    <TextBlock Text="Virtual / Cable Output"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,14,0,6"/>
                                    <ComboBox x:Name="VirtualComboBox"
                                              SelectionChanged="VirtualComboBox_SelectionChanged"/>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Grid.Column="2" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="MICROPHONE"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="Input Device"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox x:Name="MicComboBox"
                                              Margin="0,0,0,16"
                                              SelectionChanged="MicComboBox_SelectionChanged"/>

                                    <ui:ToggleSwitch x:Name="MicPassthroughCheckBox"
                                                     Content="Pass microphone to virtual output"
                                                     Margin="0,0,0,16"
                                                     Checked="MicPassthroughCheckBox_Checked"
                                                     Unchecked="MicPassthroughCheckBox_Unchecked"/>

                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   Text="Volume"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   Width="52"/>
                                        <TextBlock x:Name="MicVolumeLabel"
                                                   DockPanel.Dock="Right"
                                                   Text="80%"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Width="38"/>
                                        <Slider x:Name="MicVolumeSlider"
                                                Minimum="0" Maximum="100" Value="80"
                                                VerticalAlignment="Center"
                                                ValueChanged="MicVolumeSlider_ValueChanged"/>
                                    </DockPanel>
                                </StackPanel>
                            </ui:Card>
                        </Grid>

                        <!-- ── Audio Performance Presets ──────────────────────────────────── -->
                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>

                                <TextBlock Text="AUDIO PERFORMANCE"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Opacity="0.55"
                                           Margin="0,0,0,12"/>

                                <!-- Radio buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton x:Name="PresetStableRadio"
                                                 Content="Stable"
                                                 GroupName="AudioPreset"
                                                 Tag="Stable"
                                                 Margin="0,0,20,0"
                                                 Checked="PresetRadio_Checked"/>
                                    <RadioButton x:Name="PresetBalancedRadio"
                                                 Content="Balanced (Recommended)"
                                                 GroupName="AudioPreset"
                                                 Tag="Balanced"
                                                 Margin="0,0,20,0"
                                                 Checked="PresetRadio_Checked"/>
                                    <RadioButton x:Name="PresetLowLatencyRadio"
                                                 Content="Low Latency"
                                                 GroupName="AudioPreset"
                                                 Tag="Low Latency"
                                                 Checked="PresetRadio_Checked"/>
                                </StackPanel>

                                <!-- Dynamic description -->
                                <TextBlock x:Name="PresetDescriptionText"
                                           Text="100 ms buffer — recommended for most systems."
                                           Opacity="0.7"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <!-- Caution note -->
                                <TextBlock Text="⚠  Changing the preset recreates the audio engines and stops all playing sounds."
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>

                            </StackPanel>
                        </ui:Card>

                        <!-- ── Discord / Game Routing Wizard ──────────────────────────────── -->
                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>

                                <TextBlock Text="DISCORD / GAME ROUTING"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,16"/>

                                <!-- Routing status rows -->
                                <TextBlock Text="ROUTING STATUS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock x:Name="WizardMonitorDot"
                                               Text="●"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Monitor Output"
                                               FontSize="12"
                                               Width="130"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WizardMonitorStatusText"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock x:Name="WizardVirtualDot"
                                               Text="●"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Virtual Output"
                                               FontSize="12"
                                               Width="130"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WizardVirtualStatusText"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel x:Name="WizardMicStatusRow"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,6"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="WizardMicDot"
                                               Text="●"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="Mic Passthrough"
                                               FontSize="12"
                                               Width="130"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WizardMicStatusText"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Warning banners (collapsed by default) -->
                                <TextBlock x:Name="WizardNoVirtualWarning"
                                           Visibility="Collapsed"
                                           Text="⚠  Virtual Output is None — Discord and games will not hear SoundPad. Select a virtual cable device such as CABLE Input."
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>

                                <TextBlock x:Name="WizardConflictWarning"
                                           Visibility="Collapsed"
                                           Text="⚠  Monitor and Virtual Output appear to be the same device — sounds will play twice."
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>

                                <TextBlock x:Name="WizardMicNoDeviceWarning"
                                           Visibility="Collapsed"
                                           Text="⚠  Mic Passthrough is enabled but no microphone is selected."
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>

                                <TextBlock x:Name="WizardNoCableWarning"
                                           Visibility="Collapsed"
                                           Text="⚠  No virtual cable device detected. Install VB-CABLE or Voicemeeter so Discord can hear SoundPad."
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>

                                <Border Height="1"
                                        Background="{DynamicResource CardBorderBrush}"
                                        Margin="0,16,0,16"/>

                                <!-- Recommended Setup (hidden when no virtual cable found) -->
                                <StackPanel x:Name="WizardRecommendedPanel"
                                            Visibility="Collapsed"
                                            Margin="0,0,0,16">
                                    <TextBlock Text="RECOMMENDED SETUP"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button Content="Use Recommended Discord Setup"
                                                   Appearance="Secondary"
                                                   Click="UseRecommendedSetup_Click"/>
                                        <TextBlock x:Name="WizardRecommendedDeviceName"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Discord setup instructions -->
                                <TextBlock Text="HOW TO SET UP DISCORD"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,10"/>

                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="1.  SoundPad Virtual Output  →  CABLE Input"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="2.  Discord: Settings → Voice → Input Device  →  CABLE Output"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="3.  Enable Mic Passthrough in SoundPad to include your voice in Discord"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="4.  In Discord: disable Noise Suppression and Auto Gain Control if sounds are cut off"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Height="1"
                                        Background="{DynamicResource CardBorderBrush}"
                                        Margin="0,0,0,16"/>

                                <!-- Test tone -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <ui:Button x:Name="WizardTestButton"
                                               Content="Test Discord Output"
                                               Appearance="Secondary"
                                               Click="TestVirtualOutput_Click"/>
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               TextWrapping="Wrap"
                                               Text="Plays a 440 Hz tone to Virtual Output only — check that Discord hears it"/>
                                </StackPanel>

                                <Border Height="1"
                                        Background="{DynamicResource CardBorderBrush}"
                                        Margin="0,0,0,16"/>

                                <!-- Performance tips -->
                                <TextBlock Text="PERFORMANCE TIPS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,10"/>

                                <StackPanel>
                                    <TextBlock Text="•   Recommended sample rate: 48 kHz (matches Discord and VB-CABLE natively)"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="•   If Discord cuts sounds: disable Noise Suppression and Auto Gain Control in Discord Voice settings"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="•   Keep SoundPad open or minimized to tray for global hotkeys to work"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="GLOBAL SHORTCUTS"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Stop All Sounds"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="StopAllHotkeyText"
                                                   Text="No hotkey"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                               Content="Set Hotkey"
                                               Appearance="Secondary"
                                               Width="120"
                                               Margin="0,0,8,0"
                                               Click="SetStopAllHotkey_Click"/>
                                    <ui:Button x:Name="ClearStopAllHotkeyButton"
                                               Grid.Column="2"
                                               Content="Clear"
                                               Appearance="Secondary"
                                               Width="90"
                                               IsEnabled="False"
                                               Click="ClearStopAllHotkey_Click"/>
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <!-- ── Instant Replay / Audio Clipper ─────────────────────────────── -->
                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="INSTANT REPLAY"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,14"/>

                                <!-- Status indicator row -->
                                <DockPanel Margin="0,0,0,4">
                                    <Border x:Name="InstantReplayStatusDot"
                                            DockPanel.Dock="Left"
                                            Width="10" Height="10"
                                            CornerRadius="5"
                                            Background="Gray"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"/>
                                    <TextBlock x:Name="InstantReplayStatusText"
                                               Text="Instant Replay: OFF"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Signal level indicator (visible only while running) -->
                                <TextBlock x:Name="InstantReplaySignalText"
                                           Text=""
                                           FontSize="11"
                                           Margin="18,0,0,12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                <ui:ToggleSwitch x:Name="InstantReplaySwitch"
                                                 Content="Enable Instant Replay"
                                                 Margin="0,0,0,8"
                                                 Checked="InstantReplaySwitch_Checked"
                                                 Unchecked="InstantReplaySwitch_Unchecked"/>

                                <TextBlock Text="Captures recent system audio only when enabled. No recording occurs when off."
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14"/>

                                <!-- Buffer length -->
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Buffer length"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Width="110"/>
                                    <ComboBox x:Name="InstantReplayMinutesCombo"
                                              Width="140"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="InstantReplayMinutesCombo_SelectionChanged">
                                        <ComboBoxItem Content="1 minute"/>
                                        <ComboBoxItem Content="2 minutes"/>
                                        <ComboBoxItem Content="3 minutes"/>
                                        <ComboBoxItem Content="4 minutes"/>
                                        <ComboBoxItem Content="5 minutes"/>
                                    </ComboBox>
                                </DockPanel>

                                <!-- Capture device — which output to tap for loopback audio -->
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Capture device"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Width="110"/>
                                    <ComboBox x:Name="InstantReplayCaptureDeviceCombo"
                                              MinWidth="200"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="InstantReplayCaptureDeviceCombo_SelectionChanged"/>
                                </DockPanel>

                                <!-- ── Microphone capture (optional) ──────────────────── -->
                                <Border Height="1"
                                        Background="{DynamicResource CardBorderBrush}"
                                        Margin="0,6,0,14"/>

                                <TextBlock Text="MICROPHONE (OPTIONAL)"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,10"/>

                                <CheckBox x:Name="InstantReplayIncludeMicCheckBox"
                                          Content="Include microphone in clips"
                                          Margin="0,0,0,6"
                                          Checked="InstantReplayIncludeMicCheckBox_Checked"
                                          Unchecked="InstantReplayIncludeMicCheckBox_Unchecked"/>

                                <TextBlock Text="Microphone audio is only captured while Instant Replay is ON and Include microphone is enabled."
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="24,0,0,10"/>

                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Microphone"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Width="110"/>
                                    <ComboBox x:Name="InstantReplayMicDeviceCombo"
                                              MinWidth="200"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="InstantReplayMicDeviceCombo_SelectionChanged"/>
                                </DockPanel>

                                <TextBlock x:Name="InstantReplayMicSignalText"
                                           Text=""
                                           FontSize="11"
                                           Margin="0,0,0,10"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

                                <!-- Hint shown only while Instant Replay is ON -->
                                <TextBlock x:Name="InstantReplayLockedHint"
                                           Text="Turn Instant Replay OFF to change capture device, buffer length, or microphone settings."
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Margin="0,0,0,14"/>

                                <!-- Save Clip button -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <ui:Button x:Name="SaveInstantReplayClipButton"
                                               Content="Save Clip"
                                               Appearance="Secondary"
                                               Click="SaveInstantReplayClip_Click">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="VideoClip20"/>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>

                                <Border Height="1"
                                        Background="{DynamicResource CardBorderBrush}"
                                        Margin="0,0,0,14"/>

                                <TextBlock Text="HOTKEYS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,12"/>

                                <!-- Save Clip hotkey row -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Save Clip"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="InstantReplayClipHotkeyText"
                                                   Text="No hotkey"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Content="Set Hotkey"
                                               Appearance="Secondary"
                                               Width="120"
                                               Margin="0,0,8,0"
                                               Click="SetInstantReplayClipHotkey_Click"/>
                                    <ui:Button x:Name="ClearInstantReplayClipHotkeyButton"
                                               Grid.Column="2"
                                               Content="Clear"
                                               Appearance="Secondary"
                                               Width="90"
                                               IsEnabled="False"
                                               Click="ClearInstantReplayClipHotkey_Click"/>
                                </Grid>

                                <!-- Toggle ON/OFF hotkey row -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Toggle ON/OFF"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock x:Name="InstantReplayToggleHotkeyText"
                                                   Text="No hotkey"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <ui:Button Grid.Column="1"
                                               Content="Set Hotkey"
                                               Appearance="Secondary"
                                               Width="120"
                                               Margin="0,0,8,0"
                                               Click="SetInstantReplayToggleHotkey_Click"/>
                                    <ui:Button x:Name="ClearInstantReplayToggleHotkeyButton"
                                               Grid.Column="2"
                                               Content="Clear"
                                               Appearance="Secondary"
                                               Width="90"
                                               IsEnabled="False"
                                               Click="ClearInstantReplayToggleHotkey_Click"/>
                                </Grid>

                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="SOUND PLAYBACK"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,16"/>

                                <ui:ToggleSwitch x:Name="InterruptSoundsSwitch"
                                                 Content="Interrupt previous sound"
                                                 Checked="InterruptSoundsSwitch_Checked"
                                                 Unchecked="InterruptSoundsSwitch_Unchecked"/>

                                <TextBlock Text="When on, playing a sound stops any currently playing sounds first. Mic passthrough is unaffected."
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="BEHAVIOR"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,16"/>

                                <ui:ToggleSwitch x:Name="MinimizeToTraySwitch"
                                                 Content="Minimize to tray"
                                                 Checked="MinimizeToTraySwitch_Checked"
                                                 Unchecked="MinimizeToTraySwitch_Unchecked"/>

                                <ui:ToggleSwitch x:Name="CloseToTraySwitch"
                                                 Content="Close to tray"
                                                 Margin="0,12,0,0"
                                                 Checked="CloseToTraySwitch_Checked"
                                                 Unchecked="CloseToTraySwitch_Unchecked"/>

                                <ui:ToggleSwitch x:Name="StartWithWindowsSwitch"
                                                 Content="Start with Windows"
                                                 Margin="0,12,0,0"
                                                 Checked="StartWithWindowsSwitch_Checked"
                                                 Unchecked="StartWithWindowsSwitch_Unchecked"/>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="LIBRARY BACKUP"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Export your sound library and restore it on any device."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,16"/>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="Export Backup"
                                               Appearance="Secondary"
                                               Click="ExportBackup_Click">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="ArrowDownload20"/>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Content="Import Backup"
                                               Appearance="Secondary"
                                               Margin="12,0,0,0"
                                               Click="ImportBackup_Click">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="ArrowUpload20"/>
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="20" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="UPDATES"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Check for new SoundPad releases on GitHub."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,12"/>
                                        <ui:ToggleSwitch x:Name="AutoUpdateSwitch"
                                                         Content="Enable automatic update checks"
                                                         Checked="AutoUpdateSwitch_Checked"
                                                         Unchecked="AutoUpdateSwitch_Unchecked"/>
                                        <TextBlock Text="Automatic checks run once per day when SoundPad opens."
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <ui:Button x:Name="CheckUpdatesButton"
                                                   Content="Check for Updates"
                                                   Appearance="Secondary"
                                                   Click="CheckUpdates_Click"/>
                                        <ui:Button Content="Open Releases Page"
                                                   Appearance="Secondary"
                                                   Margin="0,8,0,0"
                                                   Click="OpenReleases_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Update-available panel: collapsed until an update is confirmed -->
                                <Border x:Name="UpdateAvailablePanel"
                                        Visibility="Collapsed"
                                        BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="14,12"
                                        Margin="0,14,0,0">
                                    <StackPanel>

                                        <!-- Version number -->
                                        <TextBlock x:Name="UpdateVersionText"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                        <!-- Release name / title (hidden when same as tag) -->
                                        <TextBlock x:Name="UpdateTitleText"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,2,0,0"
                                                   Visibility="Collapsed"/>

                                        <!-- Release notes (capped at 80px, collapsed when empty) -->
                                        <ScrollViewer x:Name="UpdateBodyScroll"
                                                      MaxHeight="80"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Margin="0,8,0,0"
                                                      Visibility="Collapsed">
                                            <TextBlock x:Name="UpdateBodyText"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>

                                        <!-- Shown when no matching .exe asset found in the release -->
                                        <TextBlock x:Name="NoAssetText"
                                                   Text="No installer file found in this release. Use Open Release Page to download manually."
                                                   Visibility="Collapsed"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0"/>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <ui:Button x:Name="DownloadInstallButton"
                                                       Content="Download &amp;&amp; Install"
                                                       Appearance="Primary"
                                                       Click="DownloadInstall_Click"/>
                                            <ui:Button Content="Open Release Page"
                                                       Appearance="Secondary"
                                                       Margin="8,0,0,0"
                                                       Click="OpenReleases_Click"/>
                                            <ui:Button x:Name="LaterButton"
                                                       Content="Later"
                                                       Appearance="Secondary"
                                                       Margin="8,0,0,0"
                                                       Click="LaterUpdate_Click"/>
                                        </StackPanel>

                                        <!-- Download progress (collapsed until download starts) -->
                                        <StackPanel x:Name="DownloadProgressPanel"
                                                    Visibility="Collapsed"
                                                    Margin="0,12,0,0">
                                            <TextBlock x:Name="DownloadStatusText"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <ProgressBar x:Name="DownloadProgressBar"
                                                         Height="6"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Margin="0,6,0,0"/>
                                            <ui:Button x:Name="CancelDownloadButton"
                                                       Content="Cancel"
                                                       Appearance="Secondary"
                                                       HorizontalAlignment="Left"
                                                       Margin="0,8,0,0"
                                                       Click="CancelDownload_Click"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Padding="20">
                            <StackPanel>
                                <TextBlock Text="ABOUT"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,16"/>

                                <TextBlock Text="SoundPad"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Margin="0,0,0,2"/>

                                <TextBlock x:Name="AboutVersionText"
                                           Text="Version 1.0.0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,6"/>

                                <TextBlock Text="Low-latency Windows soundpad for games and Discord"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,16"/>

                                <TextBlock Text="DATA FOLDER"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Margin="0,0,0,4"/>

                                <TextBlock x:Name="AboutDataFolderText"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </ui:Card>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Footer: status + fixed-size Stop All ────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="Stop All Sounds"
                           Appearance="Danger"
                           Width="200"
                           Height="44"
                           FontWeight="SemiBold"
                           Click="StopButton_Click">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Stop24"/>
                    </ui:Button.Icon>
                </ui:Button>
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,16,0"
                           Text="Ready"/>
            </DockPanel>
        </Border>

    </Grid>
</ui:FluentWindow>
