<Window x:Class="SoundPad.App.MiniWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="SoundPad Mini"
        Width="420" Height="360"
        MinWidth="220" MinHeight="180"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        FontFamily="Segoe UI"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      CornerRadius="8"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <!-- ── Header ──────────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="DeckNameText"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Margin="10,0,6,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Pin (always-on-top) toggle -->
                    <ui:Button x:Name="PinButton"
                               Grid.Column="1"
                               Content="📌"
                               Appearance="Secondary"
                               Width="28" Height="28"
                               Padding="0"
                               FontSize="11"
                               Margin="0,0,2,0"
                               ToolTip="Always on top"
                               WindowChrome.IsHitTestVisibleInChrome="True"
                               Click="PinButton_Click"/>

                    <!-- Close (hide) button -->
                    <ui:Button x:Name="CloseButton"
                               Grid.Column="2"
                               Content="✕"
                               Appearance="Secondary"
                               Width="28" Height="28"
                               Padding="0"
                               FontSize="11"
                               Margin="0,0,4,0"
                               ToolTip="Close Mini Mode"
                               WindowChrome.IsHitTestVisibleInChrome="True"
                               Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- ── Pad area ────────────────────────────────────────────────── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6,4">
                <WrapPanel x:Name="MiniPadPanel"
                           Orientation="Horizontal"
                           Margin="2"/>
            </ScrollViewer>

            <!-- ── Footer ─────────────────────────────────────────────────── -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="0,1,0,0">
                <ui:Button x:Name="StopAllButton"
                           Content="⏹ Stop All"
                           Appearance="Secondary"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Margin="6,4"
                           FontSize="12"
                           Click="StopAll_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
